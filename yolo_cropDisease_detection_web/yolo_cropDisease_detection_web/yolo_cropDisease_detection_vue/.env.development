# 本地环境
ENV = 'development'

# 本地环境接口地址
VITE_API_URL = 'http://localhost:8888/'

# axios 基础域（request.ts 使用）
# 设为根路径，所有以 /api、/flask 开头的请求交由 Vite 代理转发
VITE_API_DOMAIN = '/'

# Flask service base url (video stream endpoints)
VITE_FLASK_BASE_URL = 'http://127.0.0.1:5000'

# Flask Socket.IO base url
VITE_FLASK_SOCKET_URL = 'http://localhost:5000'

