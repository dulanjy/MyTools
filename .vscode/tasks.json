{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "start:backend",
            "type": "process",
            "command": "cmd.exe",
            "args": [
                "/d",
                "/c",
                ".\\mvnw.cmd spring-boot:run -DskipTests -Dspring-boot.run.arguments=--server.port=9999"
            ],
            "options": {
                "cwd": "${workspaceFolder}/yolo_studentBehavior_detection_web/yolo_studentBehavior_detection_springboot"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "start:frontend",
            "type": "process",
            "command": "cmd.exe",
            "args": [
                "/d",
                "/c",
                "(if not exist node_modules npm install) && set BROWSER=none && npm run dev -- --port 8888"
            ],
            "options": {
                "cwd": "${workspaceFolder}/yolo_studentBehavior_detection_web/yolo_studentBehavior_detection_vue"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "start:ml",
            "type": "process",
            "command": "cmd.exe",
            "args": [
                "/d",
                "/c",
                "start_ml_task.bat"
            ],
            "options": {
                "cwd": "${workspaceFolder}/yolo_studentBehavior_detection_web/yolo_studentBehavior_detection_flask"
            },
            "isBackground": true,
            "problemMatcher": []
        },
        {
            "label": "start:mysql",
            "type": "process",
            "command": "powershell",
            "args": [
                "-NoProfile",
                "-ExecutionPolicy",
                "Bypass",
                "-File",
                "${workspaceFolder}/.vscode/start-mysql.ps1"
            ],
            "isBackground": false,
            "problemMatcher": []
        },
        {
            "label": "start:all",
            "type": "process",
            "command": "cmd.exe",
            "args": [
                "/d",
                "/c",
                "echo starting mysql, backend, frontend, ml services"
            ],
            "dependsOn": [
                "start:mysql",
                "start:backend",
                "start:frontend",
                "start:ml"
            ],
            "dependsOrder": "parallel",
            "problemMatcher": []
        }
    ]
}
